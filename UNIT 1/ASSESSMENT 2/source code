# Hospital Doctor Scheduling using Backtracking

doctors = ["D1", "D2", "D3"]
shifts = ["Morning", "Afternoon", "Night"]

assignment = {}


# Check constraints
def is_valid(doctor, shift):

    # D1 cannot work Night
    if doctor == "D1" and shift == "Night":
        return False

    # D3 cannot work Morning
    if doctor == "D3" and shift == "Morning":
        return False

    # D2 must work before D3
    if doctor == "D3" and "D2" in assignment:
        order = {"Morning": 1, "Afternoon": 2, "Night": 3}
        if order[assignment["D2"]] >= order[shift]:
            return False

    return True


# Backtracking function
def backtracking(index):

    if index == len(doctors):
        return True

    doctor = doctors[index]

    for shift in shifts:

        if shift not in assignment.values():

            if is_valid(doctor, shift):

                assignment[doctor] = shift

                if backtracking(index + 1):
                    return True

                del assignment[doctor]

    return False


# Start Scheduling
if backtracking(0):

    print("Final Valid Schedule:")
    for doctor, shift in assignment.items():
        print(doctor, "->", shift)

else:
    print("No valid schedule found")



