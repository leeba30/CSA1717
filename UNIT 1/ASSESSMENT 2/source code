# Autonomous Rescue Robot using Uniform Cost Search (UCS)

import heapq

grid = [
    ['S', '.', '.', 'X', '.'],
    ['.', 'X', 'R', 'X', '.'],
    ['.', '.', '.', '.', '.'],
    ['X', 'R', 'X', '.', '.'],
    ['.', '.', '.', '.', 'G']
]


rows = len(grid)
cols = len(grid[0])


# Find Start and Goal
for i in range(rows):
    for j in range(cols):

        if grid[i][j] == 'S':
            start = (i, j)

        if grid[i][j] == 'G':
            goal = (i, j)


# Movement directions
moves = [
    (-1, 0),
    (1, 0),
    (0, -1),
    (0, 1)
]


# Cost Calculation
def move_cost(x, y):

    if grid[x][y] == 'R':
        return 3

    return 1


# Uniform Cost Search
def UCS(start, goal):

    priority_queue = [(0, start, [start])]
    visited = set()


    while priority_queue:

        cost, current, path = heapq.heappop(priority_queue)


        if current == goal:
            return path, cost


        if current in visited:
            continue


        visited.add(current)


        for move in moves:

            x = current[0] + move[0]
            y = current[1] + move[1]


            if (0 <= x < rows and
                0 <= y < cols and
                grid[x][y] != 'X' and
                (x, y) not in visited):


                new_cost = cost + move_cost(x, y)


                heapq.heappush(
                    priority_queue,
                    (new_cost, (x, y), path + [(x, y)])
                )


    return None, None


path, cost = UCS(start, goal)


print("\nSafe Optimal Path:")
print(path)

print("Total Cost:", cost)
