# Robot Path Finding using BFS

from collections import deque

grid = [
    ['S', '.', '.', 'X', '.'],
    ['.', 'X', '.', 'X', '.'],
    ['.', 'X', '.', '.', '.'],
    ['.', '.', 'X', 'X', '.'],
    ['X', '.', '.', '.', 'G']
]


# Find Start and Goal
for i in range(5):
    for j in range(5):
        if grid[i][j] == 'S':
            start = (i, j)
        if grid[i][j] == 'G':
            goal = (i, j)


# Possible movements
moves = [
    (-1, 0),
    (1, 0),
    (0, -1),
    (0, 1)
]


# BFS Algorithm
def bfs(start, goal):

    queue = deque([(start, [start])])
    visited = set()
    visited.add(start)

    while queue:

        current, path = queue.popleft()

        if current == goal:
            return path

        for move in moves:

            x = current[0] + move[0]
            y = current[1] + move[1]

            if (0 <= x < 5 and
                0 <= y < 5 and
                grid[x][y] != 'X' and
                (x, y) not in visited):

                visited.add((x, y))
                queue.append(((x, y), path + [(x, y)]))

    return None


path = bfs(start, goal)

print("\nOptimal Path:")
print(path)

print("Path Cost:", len(path)-1)



