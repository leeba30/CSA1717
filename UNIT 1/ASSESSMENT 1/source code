# ==========================================
# Question 5: Uniform Cost Search (UCS)
# ==========================================

import heapq

graph = {
    'S': [('A',1), ('G',12)],
    'A': [('B',3), ('C',1)],
    'B': [('D',3)],
    'C': [('D',1), ('G',2)],
    'D': [('G',3)]
}

def UCS(start, goal):

    queue = [(0, start, [start])]

    while queue:
        cost, node, path = heapq.heappop(queue)

        if node == goal:
            return cost, path

        for next_node, weight in graph.get(node, []):
            heapq.heappush(queue,
                           (cost + weight,
                            next_node,
                            path + [next_node]))

print("\nQuestion 5: Uniform Cost Search")

cost, path = UCS('S', 'G')

print("Optimal Path:", path)
print("Total Cost:", cost)
